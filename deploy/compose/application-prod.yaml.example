server:
  port: 9090
  servlet:
    context-path: /api/ragent

spring:
  application:
    name: ragent-service

  servlet:
    multipart:
      max-file-size: 50MB
      max-request-size: 100MB

  datasource:
    driver-class-name: org.postgresql.Driver
    type: com.zaxxer.hikari.HikariDataSource
    # Placeholder only. Stage 2 must provide the real PostgreSQL user externally.
    username: ${RAGENT_POSTGRES_USERNAME:CHANGE_ME}
    # Placeholder only. Do not commit real passwords.
    password: ${RAGENT_POSTGRES_PASSWORD:CHANGE_ME}
    # Example points to an externally managed database, not a Stage 1 managed container.
    url: ${RAGENT_POSTGRES_URL:jdbc:postgresql://postgres-host:5432/ragent?client_encoding=UTF8}
    hikari:
      connection-timeout: 5000
      idle-timeout: 600000
      max-lifetime: 1800000
      maximum-pool-size: ${RAGENT_DB_MAX_POOL_SIZE:10}
      minimum-idle: ${RAGENT_DB_MIN_IDLE:5}
      pool-name: RagentHikariPool

  data:
    redis:
      host: ${RAGENT_REDIS_HOST:redis-host}
      port: ${RAGENT_REDIS_PORT:6379}
      password: ${RAGENT_REDIS_PASSWORD:CHANGE_ME}

rocketmq:
  name-server: ${RAGENT_ROCKETMQ_NAME_SERVER:rocketmq-host:9876}
  producer:
    group: ${RAGENT_ROCKETMQ_PRODUCER_GROUP:ragent-producer_pg}
    send-message-timeout: 2000

milvus:
  uri: ${RAGENT_MILVUS_URI:http://milvus-host:19530}

rag:
  vector:
    type: ${RAGENT_VECTOR_TYPE:pg}

  default:
    collection-name: ${RAGENT_DEFAULT_COLLECTION:rag_default_store}
    dimension: ${RAGENT_VECTOR_DIMENSION:1536}
    metric-type: COSINE
    sse-timeout-ms: ${RAGENT_SSE_TIMEOUT_MS:300000}

  query-rewrite:
    enabled: true

  rerank:
    enabled: true

  rate-limit:
    global:
      enabled: true
      max-concurrent: ${RAGENT_CHAT_MAX_CONCURRENT:10}
      max-wait-seconds: ${RAGENT_CHAT_MAX_WAIT_SECONDS:15}
      lease-seconds: 30
      poll-interval-ms: 200

  memory:
    history-keep-turns: 4
    summary-start-turns: 5
    summary-enabled: true
    summary-max-chars: 200
    title-max-length: 30

  semaphore:
    document-upload:
      name: rag:document:upload
      max-concurrent: 10
      max-wait-seconds: 5
      lease-seconds: 300

  knowledge:
    schedule:
      scan-delay-ms: 10000
      lock-seconds: 900
      batch-size: 20
      min-interval-seconds: 60

  mcp:
    servers:
      - name: default
        url: ${RAGENT_MCP_DEFAULT_URL:http://mcp-host:9099}

  search:
    channels:
      vector-global:
        confidence-threshold: 0.6
        top-k-multiplier: 3
      intent-directed:
        enabled: true
        min-intent-score: 0.4
        top-k-multiplier: 2

  trace:
    enabled: true
    max-error-length: 1000

ai:
  providers:
    ollama:
      url: ${RAGENT_OLLAMA_URL:http://ollama-host:11434}
      endpoints:
        chat: /v1/chat/completions
        embedding: /v1/embeddings
    bailian:
      url: ${RAGENT_BAILIAN_URL:https://dashscope.aliyuncs.com}
      endpoints:
        chat: /compatible-mode/v1/chat/completions
        rerank: /api/v1/services/rerank/text-rerank/text-rerank
    aihubmix:
      url: ${RAGENT_AIHUBMIX_URL:https://aihubmix.com}
      endpoints:
        chat: /v1/chat/completions
        embedding: /v1/embeddings
    siliconflow:
      url: ${RAGENT_SILICONFLOW_URL:https://api.siliconflow.cn}
      endpoints:
        chat: /v1/chat/completions
        embedding: /v1/embeddings

  selection:
    failure-threshold: 2
    open-duration-ms: 30000

  stream:
    message-chunk-size: 1

  chat:
    default-model: ${RAGENT_CHAT_DEFAULT_MODEL:qwen-plus}
    deep-thinking-model: ${RAGENT_CHAT_DEEP_THINKING_MODEL:qwen3-max}
    candidates:
      - id: qwen-plus
        provider: bailian
        model: qwen-plus-latest
        priority: 1
      - id: qwen3-local
        provider: ollama
        model: qwen3:8b-fp16
        priority: 2
      - id: qwen3-max
        provider: bailian
        model: qwen3-max
        supports-thinking: true
        priority: 3
      - id: glm-4.7
        provider: siliconflow
        model: Pro/zai-org/GLM-4.7
        supports-thinking: true
        priority: 4
      - id: gpt-5.4
        provider: aihubmix
        model: gpt-5.4
        priority: 5

  embedding:
    default-model: ${RAGENT_EMBEDDING_DEFAULT_MODEL:qwen-emb-8b}
    candidates:
      - id: qwen-emb-8b
        provider: siliconflow
        model: Qwen/Qwen3-Embedding-8B
        dimension: ${rag.default.dimension}
        priority: 1
      - id: qwen-emb-local
        provider: ollama
        model: qwen3-embedding:8b-fp16
        dimension: ${rag.default.dimension}
        priority: 2
      - id: text-embedding-3-large
        provider: aihubmix
        model: text-embedding-3-large
        dimension: ${rag.default.dimension}
        priority: 3

  rerank:
    default-model: ${RAGENT_RERANK_DEFAULT_MODEL:qwen3-rerank}
    candidates:
      - id: qwen3-rerank
        provider: bailian
        model: qwen3-rerank
        priority: 1
      - id: rerank-noop
        provider: noop
        model: noop
        priority: 100

rustfs:
  url: ${RAGENT_RUSTFS_URL:http://rustfs-host:29000}
  access-key-id: ${RAGENT_RUSTFS_ACCESS_KEY_ID:CHANGE_ME}
  secret-access-key: ${RAGENT_RUSTFS_SECRET_ACCESS_KEY:CHANGE_ME}

sa-token:
  token-name: Authorization
  timeout: 2592000
  is-concurrent: true
  is-share: false
  token-style: simple-uuid
  is-log: false
  is-print: false

app:
  demo-mode: ${RAGENT_DEMO_MODE:false}
  eval:
    enabled: false