# Immutable image references selected by local build or a future release pipeline.
# Do not use floating latest-only tags in production.
RAGENT_API_IMAGE=ragent-api:local
RAGENT_WEB_IMAGE=ragent-web:local

# Web is the only service that publishes a host port. Default is loopback-only.
RAGENT_WEB_BIND_HOST=127.0.0.1
RAGENT_WEB_PORT=18080

# Spring runtime profile and external config mount.
SPRING_PROFILES_ACTIVE=prod
SPRING_CONFIG_ADDITIONAL_LOCATION=optional:file:/config/
RAGENT_API_CONFIG_FILE=./application-prod.yaml.example

# JVM options, for example: -Xms512m -Xmx1024m
RAGENT_API_JAVA_OPTS=